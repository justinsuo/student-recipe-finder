{
  "expo": {
    "name": "Waivy",
    "slug": "waivy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "waivy",
    "userInterfaceStyle": "light",
    "backgroundColor": "#FFF8ED",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.waivy.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.waivy.app",
      "adaptiveIcon": {
        "backgroundColor": "#FFF8ED",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFF8ED",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 96
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Waivy uses your photos to read ingredients from fridge and meal photos.",
          "cameraPermission": "Waivy uses the camera to scan your pantry, fridge, and meals."
        }
      ],
      "expo-notifications",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": false,
      "reactCompiler": false
    },
    "extra": {
      "eas": {}
    }
  }
}
