# Waivy iPhone app — optional build-time config (Expo inlines EXPO_PUBLIC_*).
# Everything also works without these (offline/local), and they can be set at
# runtime in the app's Settings instead.

# Cloudflare Worker that proxies OpenAI (recipe generation, images, pricing) and
# hosts cross-device sync. The OpenAI key stays on the Worker — never in the app.
EXPO_PUBLIC_WORKER_URL=

# Optional Anthropic Haiku key for fast on-device AI (pantry photo/paste parsing,
# the chat). Optional by design — the app degrades gracefully without it.
EXPO_PUBLIC_ANTHROPIC_API_KEY=

# Optional USDA FoodData Central key for the Nourish food search (falls back to
# DEMO_KEY, then to custom foods + manual entry).
EXPO_PUBLIC_USDA_API_KEY=
