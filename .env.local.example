# ─── Recipe APIs ────────────────────────────────────────────────────────────
# Add at least ONE of these to enable the Explore page with real recipes.

# Spoonacular — 150 points/day free  https://spoonacular.com/food-api
NEXT_PUBLIC_SPOONACULAR_API_KEY=

# Edamam — 10,000 calls/month free  https://developer.edamam.com
NEXT_PUBLIC_EDAMAM_APP_ID=
NEXT_PUBLIC_EDAMAM_APP_KEY=

# TheMealDB — totally free, no key needed (small catalogue ~300 meals)
# Just set DATA_SOURCE=themealdb and it works without any key.

# Which API to use for the Explore page: spoonacular | edamam | themealdb | mock
NEXT_PUBLIC_EXPLORE_SOURCE=mock

# ─── AI (Anthropic) — already used by the Pantry feature ───────────────────
ANTHROPIC_API_KEY=
